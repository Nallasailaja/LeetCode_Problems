class Solution:
    def maximumWealth(self, accounts: List[List[int]]) -> int:
        n = len(accounts)
        m = len(accounts[0])
        maxx = 0
        for i in range(n):
            sum = 0
            for j in range(m):
                sum += accounts[i][j]
            if sum > maxx:
                maxx = sum
        return maxx
